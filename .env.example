# Copy this file to .env and fill in your values.
# Variables already set in the environment take precedence over .env.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://localhost/shopping?sslmode=disable

# ── WebAuthn / Passkeys ───────────────────────────────────────────────────────
# RPID must be the bare domain (no scheme, no port).
# ORIGIN must be the full origin your browser sees.
WEBAUTHN_RPID=localhost
WEBAUTHN_ORIGIN=http://localhost:8080

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_ADDR=:8080

# ── Bootstrap (first run only) ────────────────────────────────────────────────
# If set and no users exist, the server prints a registration link on startup.
# Can be removed from .env after the first account is created.
BOOTSTRAP_EMAIL=you@example.com

# ── LLM classifier (optional) ─────────────────────────────────────────────────
# Both variables must be set to enable classification. Run `make` to build
# llama-server, and `make download-model` to fetch the model.
# Leave blank to assign new items to "Other" without LLM classification.
LLAMA_SERVER_PATH=llama/build/bin/llama-server
LLAMA_MODEL_PATH=models/google_gemma-4-E4B-it-Q4_K_M.gguf
# Filename only — docker-compose uses this to build the in-container path:
MODEL_FILE=google_gemma-4-E4B-it-Q4_K_M.gguf

# ── SMTP (optional — required only for user invitations) ──────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost
